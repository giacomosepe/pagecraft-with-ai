---
/**
 * write.astro
 * -----------------------------------------------------------------
 * Page: /dashboard/write
 * Route: /dashboard/write?framework=<slug>
 * -----------------------------------------------------------------
 * Responsibilities (this file only):
 *   1. Read ?framework= from URL, redirect if missing
 *   2. Fetch framework + default prompts from MongoDB
 *   3. Pass data to client via window.__WRITE_DATA__
 *   4. Assemble all screen components
 *
 * Screens (each is its own component):
 *   SetupScreen    → collects title, audience, tone, language
 *   WriteScreen    → StepList (left) + StepCard + OutputCard (right)
 *   CompleteScreen → export buttons
 *
 * Modals / overlays:
 *   GenerateModal  → opens when "Generate with AI" clicked
 *
 * All components live in: src/components/write/
 * All client logic lives in: src/scripts/write/index.ts
 * -----------------------------------------------------------------
 */

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { connectDB } from "../../lib/db";
import { Framework, Prompt } from "../../lib/models";

// Screens
import SetupScreen from "../../components/write/SetupScreen.astro";
import CompleteScreen from "../../components/write/CompleteScreen.astro";

// Write screen panels
import StepList from "../../components/write/StepList.astro";
import StepCard from "../../components/write/StepCard.astro";
import OutputCard from "../../components/write/OutputCard.astro";

// Overlays
import GenerateModal from "../../components/write/GenerateModal.astro";

// ── DATA FETCHING ──
const frameworkSlug = Astro.url.searchParams.get("framework");
if (!frameworkSlug) return Astro.redirect("/dashboard/new");

await connectDB();

const framework = await Framework.findOne({ slug: frameworkSlug }).lean();
if (!framework) return Astro.redirect("/dashboard/new");

const defaultPrompts = await Prompt.find({
    frameworkSlug,
    isDefault: true,
}).lean();

// Build a stepOrder → promptText map for quick lookup in state.ts
const promptsByStep = defaultPrompts.reduce(
    (acc, p) => {
        acc[p.stepOrder] = p.instructionText;
        return acc;
    },
    {} as Record<number, string>,
);

// Serialised for client — read by src/scripts/write/state.ts
const frameworkData = JSON.stringify(framework);
const promptsData = JSON.stringify(promptsByStep);

// Sort steps once here so all components get them in order
const sortedSteps = [...framework.steps].sort((a, b) => a.order - b.order);
---

<DashboardLayout title="Write — {framework.name}">
    <!-- Screen 1: Setup — shown on page load -->
    <SetupScreen name={framework.name} description={framework.description} />

    <!-- Screen 2: Write — hidden until setup is complete -->
    <div id="write-screen" class="hidden h-full">
        <div class="flex" style="min-height: calc(100vh - 57px);">
            <!-- Left panel: framework info + step list -->
            <StepList
                name={framework.name}
                category={framework.category}
                steps={sortedSteps}
            />

            <!-- Right panel: active step card + AI output -->
            <div class="flex-1 overflow-y-auto p-8">
                <StepCard
                    category={framework.category}
                    totalSteps={sortedSteps.length}
                />
                <OutputCard />
            </div>
        </div>
    </div>

    <!-- Screen 3: Complete — hidden until all steps resolved -->
    <CompleteScreen />

    <!-- Overlay: Generate modal — hidden until "Generate with AI" clicked -->
    <GenerateModal />
</DashboardLayout>

<!--
    Data bridge — passes MongoDB data to the client.
    window.__WRITE_DATA__ is read by src/scripts/write/state.ts
-->
<script define:vars={{ frameworkData, promptsData }}>
    window.__WRITE_DATA__ = { frameworkData, promptsData };
</script>

<!-- Entry point for all write page client logic -->
<script src="../../scripts/write/index.ts"></script>
