---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { connectDB } from "../../lib/db";
import { Framework, Prompt } from "../../lib/models";
import Button from "../../components/Button.astro";

const frameworkSlug = Astro.url.searchParams.get("framework");
if (!frameworkSlug) return Astro.redirect("/dashboard/new");

await connectDB();

const framework = await Framework.findOne({ slug: frameworkSlug }).lean();
if (!framework) return Astro.redirect("/dashboard/new");

const defaultPrompts = await Prompt.find({
    frameworkSlug,
    isDefault: true,
}).lean();

const promptsByStep = defaultPrompts.reduce(
    (acc, p) => {
        acc[p.stepOrder] = p.instructionText;
        return acc;
    },
    {} as Record<number, string>,
);

const frameworkData = JSON.stringify(framework);
const promptsData = JSON.stringify(promptsByStep);
---

<DashboardLayout title="Write your page following the prompts">
    <!-- Setup Screen -->
    <div id="setup-screen" class="max-w-xl mx-auto mt-12 px-6">
        <div class="mb-8">
            <h2
                class="text-2xl font-bold mb-2"
                style="color: var(--color-heading)"
            >
                {framework.name}
            </h2>
            <p class="text-sm" style="color: var(--color-muted)">
                {framework.description}
            </p>
        </div>

        <div class="card">
            <div class="flex flex-col gap-4">
                <div>
                    <label
                        class="block text-sm font-medium mb-1"
                        style="color: var(--color-body)"
                    >
                        Page Title <span
                            style="color: var(--color-muted)"
                            class="font-normal">(optional)</span
                        >
                    </label>
                    <input
                        id="setup-title"
                        type="text"
                        placeholder="e.g. Why I switched to Astro"
                        class="input"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-medium mb-1"
                        style="color: var(--color-body)"
                    >
                        Target Audience <span class="text-red-400">*</span>
                    </label>
                    <input
                        id="setup-audience"
                        type="text"
                        placeholder="e.g. Indie hackers, newsletter writers"
                        class="input"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-medium mb-1"
                        style="color: var(--color-body)"
                    >
                        Tone <span class="text-red-400">*</span>
                    </label>
                    <select id="setup-tone" class="input">
                        <option value="">Select a tone...</option>
                        <option value="conversational">Conversational</option>
                        <option value="professional">Professional</option>
                        <option value="authoritative">Authoritative</option>
                        <option value="friendly">Friendly</option>
                        <option value="educational">Educational</option>
                        <option value="storytelling">Storytelling</option>
                        <option value="persuasive">Persuasive</option>
                    </select>
                </div>
                <div>
                    <label
                        class="block text-sm font-medium mb-1"
                        style="color: var(--color-body)"
                    >
                        Language
                    </label>
                    <select id="setup-language" class="input">
                        <option value="en">English</option>
                        <option value="it">Italian</option>
                    </select>
                </div>
                <Button variant="primary" id="start-btn"
                    >Start Writing →
                </Button>
            </div>
        </div>
    </div>

    <!-- Write Screen -->
    <div id="write-screen" class="hidden h-full">
        <div class="flex" style="min-height: calc(100vh - 57px);">
            <!-- Left Panel — 1fr -->
            <div
                class="w-64 flex-shrink-0 border-r p-6 flex flex-col"
                style="border-color: var(--color-border); background: var(--color-bg);"
            >
                <!-- Framework name -->
                <div class="mb-6">
                    <p
                        class="text-xs font-medium mb-1"
                        style="color: var(--color-muted)"
                    >
                        Framework
                    </p>
                    <h3
                        class="font-semibold text-sm"
                        style="color: var(--color-heading)"
                    >
                        {framework.name}
                    </h3>
                </div>

                <!-- Context pills -->
                <div class="mb-6">
                    <p class="text-xs mb-2" style="color: var(--color-muted)">
                        Writing for
                    </p>
                    <span id="context-category" class="badge badge-accent"
                        >{framework.category}</span
                    >
                </div>

                <hr style="border-color: var(--color-border)" class="mb-4" />

                <!-- Step list -->
                <p
                    class="text-xs font-medium mb-3"
                    style="color: var(--color-muted)"
                >
                    Steps
                </p>
                <ul id="step-list" class="flex flex-col gap-1 flex-1">
                    {
                        framework.steps
                            .sort((a, b) => a.order - b.order)
                            .map((step, i) => (
                                <li
                                    data-index={i}
                                    class="step-list-item flex items-center gap-2 px-3 py-2 rounded-md text-sm cursor-pointer transition-all"
                                    style="color: var(--color-muted)"
                                >
                                    <span class="step-icon w-4 h-4 flex-shrink-0 text-xs flex items-center justify-center">
                                        {i + 1}
                                    </span>
                                    <span class="step-label truncate">
                                        {step.title}
                                    </span>
                                </li>
                            ))
                    }
                </ul>
            </div>

            <!-- Right Panel — 2fr -->
            <div class="flex-1 overflow-y-auto p-8">
                <!-- Progress -->
                <div class="mb-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs" style="color: var(--color-muted)">
                            Step <span id="current-step-num">1</span> of <span
                                id="total-steps">{framework.steps.length}</span
                            >
                        </span>
                        <span
                            id="step-title-top"
                            class="text-xs font-medium"
                            style="color: var(--color-body)"></span>
                    </div>
                    <div
                        class="w-full rounded-full h-1"
                        style="background: var(--color-border)"
                    >
                        <div
                            id="progress-bar"
                            class="h-1 rounded-full transition-all"
                            style="width: 0%; background: var(--color-accent)"
                        >
                        </div>
                    </div>
                </div>

                <!-- Step Card -->
                <div class="card mb-4">
                    <div class="mb-4">
                        <p
                            class="text-xs mb-3"
                            style="color: var(--color-muted)"
                        >
                            This page is being written for a
                            <span
                                id="step-category-pill"
                                class="badge badge-accent"
                                >{framework.category}</span
                            > job
                        </p>
                        <h3
                            id="step-title"
                            class="text-lg font-semibold mb-1"
                            style="color: var(--color-heading)"
                        >
                        </h3>
                        <p
                            id="step-description"
                            class="text-sm"
                            style="color: var(--color-muted)"
                        >
                        </p>
                    </div>

                    <hr class="divider" />

                    <!-- User input -->
                    <div class="mb-4">
                        <label
                            class="block text-sm font-medium mb-1"
                            style="color: var(--color-body)">Your input</label
                        >
                        <textarea
                            id="user-input"
                            rows="4"
                            class="input resize-none"
                            placeholder="Write your input here..."></textarea>
                    </div>

                    <!-- Prompt collapsible -->
                    <div class="mb-6">
                        <button
                            id="toggle-prompt"
                            class="flex items-center gap-1 text-xs transition-colors"
                            style="color: var(--color-muted)"
                        >
                            <svg
                                class="w-3 h-3 transition-transform"
                                id="prompt-chevron"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="m9 5 7 7-7 7"></path>
                            </svg>
                            AI Prompt
                        </button>
                        <div id="prompt-container" class="hidden mt-2">
                            <textarea
                                id="prompt-text"
                                rows="5"
                                class="input resize-none font-mono"
                                style="font-size: 0.75rem; color: var(--color-muted)"
                            ></textarea>
                            <button
                                id="reset-prompt"
                                class="text-xs mt-1 transition-colors"
                                style="color: var(--color-muted)"
                            >
                                ↺ Reset to default
                            </button>
                        </div>
                    </div>

                    <!-- 3 action buttons -->
                    <div class="flex items-center justify-between gap-2">
                        <!-- Left group: manual -->
                        <div class="flex gap-2">
                            <Button variant="primary" id="save-btn">Save</Button
                            >
                            <Button variant="secondary" id="skip-btn"
                                >Skip for now</Button
                            >
                        </div>

                        <!-- Divider -->
                        <div
                            class="w-px h-6 flex-shrink-0"
                            style="background: var(--color-border)"
                        >
                        </div>

                        <!-- Right group: AI -->
                        <div class="flex gap-2">
                            <Button variant="secondary" id="improve-btn"
                                >Improve with AI</Button
                            >
                            <Button variant="warning" id="generate-btn"
                                >✦ Generate with AI</Button
                            >
                        </div>
                    </div>

                    <!-- Improve box (hidden until Improve clicked) -->
                    <div
                        id="improve-box"
                        class="hidden mt-4 p-4 rounded-lg"
                        style="background: var(--color-accent-light)"
                    >
                        <label
                            class="block text-sm font-medium mb-1"
                            style="color: var(--color-accent-text)"
                        >
                            What should AI improve?
                        </label>
                        <textarea
                            id="improve-input"
                            rows="2"
                            placeholder="e.g. Make it shorter, more emotional, add a specific example..."
                            class="input resize-none mb-2"></textarea>
                        <div class="flex gap-2">
                            <Button variant="secondary" id="improve-cancel-btn"
                                >Cancel</Button
                            >
                            <Button variant="warning" id="improve-confirm-btn"
                                >✦ Improve</Button
                            >
                        </div>
                    </div>

                    <!-- AI Output Card -->
                    <div id="output-card" class="card hidden mb-4">
                        <div class="flex items-center justify-between mb-3">
                            <span
                                class="text-sm font-medium"
                                style="color: var(--color-body)"
                                >Generated content</span
                            >
                            <span class="badge badge-accent">AI</span>
                        </div>
                        <div
                            id="ai-output"
                            class="text-sm leading-relaxed whitespace-pre-wrap mb-4"
                            style="color: var(--color-body)"
                        >
                        </div>

                        <hr class="divider" />

                        <div class="mb-4">
                            <label
                                class="block text-sm font-medium mb-1"
                                style="color: var(--color-body)"
                            >
                                Want improvements?
                                <span
                                    class="font-normal"
                                    style="color: var(--color-muted)"
                                    >Tell AI what to change</span
                                >
                            </label>
                            <textarea
                                id="refinement-input"
                                rows="2"
                                placeholder="e.g. Make it shorter, more personal, add a metaphor..."
                                class="input resize-none"></textarea>
                        </div>

                        <div class="flex gap-2">
                            <Button variant="secondary" id="refine-btn"
                                >↺ Refine</Button
                            >
                            <Button variant="primary" id="approve-btn"
                                >Approve & Next →</Button
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Complete Screen -->
        <div
            id="complete-screen"
            class="hidden max-w-xl mx-auto mt-12 px-6 text-center"
        >
            <div class="text-4xl mb-4">✦</div>
            <h2
                class="text-2xl font-bold mb-2"
                style="color: var(--color-heading)"
            >
                Page complete!
            </h2>
            <p class="mb-8" style="color: var(--color-muted)">
                All steps done. Your page is ready to export.
            </p>
            <div class="flex gap-3 justify-center">
                <Button variant="primary" id="export-md-btn"
                    >Export as .md</Button
                >
                <Button variant="secondary" id="copy-btn"
                    >Copy to clipboard</Button
                >
            </div>
        </div>
    </div>

    <script define:vars={{ frameworkData, promptsData }}>
        const framework = JSON.parse(frameworkData);
        const promptsByStep = JSON.parse(promptsData);
        const steps = framework.steps.sort((a, b) => a.order - b.order);

        // State
        let currentStepIndex = 0;
        let sessionData = {
            title: "Untitled",
            audience: "",
            tone: "",
            language: "en",
            steps: steps.map((s) => ({
                order: s.order,
                userInput: "",
                aiGenerated: "",
                customPrompt: null,
                approved: false,
                skipped: false,
            })),
        };

        // Elements
        const setupScreen = document.getElementById("setup-screen");
        const writeScreen = document.getElementById("write-screen");
        const completeScreen = document.getElementById("complete-screen");
        const stepItems = document.querySelectorAll(".step-list-item");

        // ── SETUP ──
        document.getElementById("start-btn")?.addEventListener("click", () => {
            const audience = document
                .getElementById("setup-audience")
                .value.trim();
            const tone = document.getElementById("setup-tone").value;
            if (!audience || !tone) {
                alert("Please fill in audience and tone before starting.");
                return;
            }
            sessionData.title =
                document.getElementById("setup-title").value.trim() ||
                "Untitled";
            sessionData.audience = audience;
            sessionData.tone = tone;
            sessionData.language =
                document.getElementById("setup-language").value;

            setupScreen.classList.add("hidden");
            writeScreen.classList.remove("hidden");
            loadStep(0);
        });

        // ── UPDATE STEP LIST ──
        function updateStepList() {
            stepItems.forEach((item, i) => {
                const icon = item.querySelector(".step-icon");
                const isActive = i === currentStepIndex;
                const isApproved = sessionData.steps[i].approved;
                const isSkipped = sessionData.steps[i].skipped;

                // Reset styles
                item.style.color = "var(--color-muted)";
                item.style.background = "transparent";
                item.style.fontWeight = "normal";

                if (isApproved) {
                    icon.textContent = "✓";
                    icon.style.color = "var(--color-accent)";
                } else if (isSkipped) {
                    icon.textContent = "✕";
                    icon.style.color = "var(--color-error)";
                } else {
                    icon.textContent = i + 1;
                    icon.style.color = "";
                }

                if (isActive) {
                    item.style.background = "var(--color-accent-light)";
                    item.style.color = "var(--color-accent-text)";
                    item.style.fontWeight = "500";
                }
            });
        }

        // ── STEP LIST CLICK ──
        stepItems.forEach((item, i) => {
            item.addEventListener("click", () => {
                loadStep(i);
            });
        });

        // ── LOAD STEP ──
        function loadStep(index) {
            currentStepIndex = index;
            const step = steps[index];

            // Progress
            const progress = (index / steps.length) * 100;
            document.getElementById("progress-bar").style.width =
                progress + "%";
            document.getElementById("current-step-num").textContent = index + 1;

            // Step info
            document.getElementById("step-title").textContent = step.title;
            document.getElementById("step-title-top").textContent = step.title;
            document.getElementById("step-description").textContent =
                step.description;

            // User input
            const userInputEl = document.getElementById("user-input");
            userInputEl.placeholder =
                step.placeholder || "Write your input here...";
            userInputEl.value = sessionData.steps[index].userInput || "";

            // Prompt
            const defaultPrompt = promptsByStep[step.order] || "";
            document.getElementById("prompt-text").value =
                sessionData.steps[index].customPrompt || defaultPrompt;

            // Output
            const outputCard = document.getElementById("output-card");
            if (sessionData.steps[index].aiGenerated) {
                document.getElementById("ai-output").textContent =
                    sessionData.steps[index].aiGenerated;
                outputCard.classList.remove("hidden");
            } else {
                outputCard.classList.add("hidden");
            }

            // Reset improve box
            document.getElementById("improve-box").classList.add("hidden");
            document.getElementById("improve-input").value = "";

            updateStepList();
        }

        // ── SAVE INPUT ON TYPE ──
        document
            .getElementById("user-input")
            ?.addEventListener("input", (e) => {
                sessionData.steps[currentStepIndex].userInput = e.target.value;
            });

        // ── TOGGLE PROMPT ──
        document
            .getElementById("toggle-prompt")
            ?.addEventListener("click", () => {
                const container = document.getElementById("prompt-container");
                const chevron = document.getElementById("prompt-chevron");
                container.classList.toggle("hidden");
                chevron.classList.toggle("rotate-90");
            });

        // ── RESET PROMPT ──
        document
            .getElementById("reset-prompt")
            ?.addEventListener("click", () => {
                const step = steps[currentStepIndex];
                document.getElementById("prompt-text").value =
                    promptsByStep[step.order] || "";
                sessionData.steps[currentStepIndex].customPrompt = null;
            });

        // ── SAVE ──
        document.getElementById("save-btn")?.addEventListener("click", () => {
            const userInput = document
                .getElementById("user-input")
                .value.trim();
            if (!userInput) {
                alert("Nothing to save yet.");
                return;
            }
            sessionData.steps[currentStepIndex].userInput = userInput;
            sessionData.steps[currentStepIndex].approved = true;
            sessionData.steps[currentStepIndex].skipped = false;

            updateStepList();

            // Move to next if not last
            if (currentStepIndex < steps.length - 1) {
                loadStep(currentStepIndex + 1);
            } else {
                checkComplete();
            }
        });

        // ── SKIP ──
        document.getElementById("skip-btn")?.addEventListener("click", () => {
            sessionData.steps[currentStepIndex].skipped = true;
            sessionData.steps[currentStepIndex].approved = false;
            updateStepList();

            if (currentStepIndex < steps.length - 1) {
                loadStep(currentStepIndex + 1);
            } else {
                checkComplete();
            }
        });
        // ── AI HELPER for prompts ──
        async function callGenerate(payload) {
            const res = await fetch("/api/generate", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });
            const data = await res.json();
            if (!res.ok || data.error) {
                throw new Error(data.error || "Generation failed");
            }
            return data.result;
        }
        // ── GENERATE With AI => called FROM /lib/ai.ts ──
        document
            .getElementById("generate-btn")
            ?.addEventListener("click", async () => {
                const userInput = document
                    .getElementById("user-input")
                    .value.trim();
                if (!userInput) {
                    alert("Please fill in your input.");
                    return;
                }

                try {
                    const result = await callGenerate({
                        mode: "generate",
                        userInput,
                        prompt: document.getElementById("prompt-text").value,
                        tone: sessionData.tone,
                        audience: sessionData.audience,
                        language: sessionData.language,
                    });
                    sessionData.steps[currentStepIndex].aiGenerated = result;
                    document.getElementById("ai-output").textContent = result;
                    document
                        .getElementById("output-card")
                        .classList.remove("hidden");
                } catch (err) {
                    alert(err.message);
                }
            });

        // ── IMPROVE WITH AI => Called from /lib/ai.ts ──
        document
            .getElementById("improve-confirm-btn")
            ?.addEventListener("click", async () => {
                const userInput = document
                    .getElementById("user-input")
                    .value.trim();
                const instructions = document
                    .getElementById("improve-input")
                    .value.trim(); // ← read from textarea
                if (!instructions) {
                    alert("Tell AI what to improve first.");
                    return;
                }

                try {
                    const result = await callGenerate({
                        mode: "improve",
                        userInput,
                        instructions,
                        tone: sessionData.tone,
                        audience: sessionData.audience,
                        language: sessionData.language,
                    });
                    sessionData.steps[currentStepIndex].aiGenerated = result;
                    document.getElementById("ai-output").textContent = result;
                    document
                        .getElementById("output-card")
                        .classList.remove("hidden");
                    document
                        .getElementById("improve-box")
                        .classList.add("hidden");
                    document.getElementById("improve-input").value = "";
                } catch (err) {
                    alert(err.message);
                }
            });
        // improve cancel
        document
            .getElementById("improve-cancel-btn")
            ?.addEventListener("click", () => {
                document.getElementById("improve-box").classList.add("hidden");
                document.getElementById("improve-input").value = "";
            });

        // ── APPROVE & NEXT ──
        document
            .getElementById("approve-btn")
            ?.addEventListener("click", () => {
                sessionData.steps[currentStepIndex].approved = true;
                sessionData.steps[currentStepIndex].skipped = false;
                updateStepList();

                if (currentStepIndex < steps.length - 1) {
                    loadStep(currentStepIndex + 1);
                } else {
                    checkComplete();
                }
            });

        // ── REFINE with AI=> Called from /lib/ai.ts ──
        document
            .getElementById("refine-btn")
            ?.addEventListener("click", async () => {
                const instructions = document
                    .getElementById("refinement-input")
                    .value.trim(); // ← read from textarea
                if (!instructions) {
                    alert("Tell AI what to refine first.");
                    return;
                }

                try {
                    const result = await callGenerate({
                        mode: "refine",
                        aiOutput:
                            sessionData.steps[currentStepIndex].aiGenerated,
                        instructions,
                        tone: sessionData.tone,
                        audience: sessionData.audience,
                        language: sessionData.language,
                    });
                    sessionData.steps[currentStepIndex].aiGenerated = result;
                    document.getElementById("ai-output").textContent = result;
                    document.getElementById("refinement-input").value = "";
                } catch (err) {
                    alert(err.message);
                }
            });

        // ── CHECK COMPLETE ──
        function checkComplete() {
            const allDone = sessionData.steps.every(
                (s) => s.approved || s.skipped,
            );
            if (allDone) {
                writeScreen.classList.add("hidden");
                completeScreen.classList.remove("hidden");
            }
        }

        // ── EXPORT ──
        document
            .getElementById("export-md-btn")
            ?.addEventListener("click", () => {
                let md = `# ${sessionData.title}\n\n`;
                sessionData.steps.forEach((s, i) => {
                    if (s.aiGenerated || s.userInput) {
                        md += `## ${steps[i].title}\n\n${s.aiGenerated || s.userInput}\n\n`;
                    }
                });
                const blob = new Blob([md], { type: "text/markdown" });
                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;
                a.download = `${sessionData.title.toLowerCase().replace(/\s+/g, "-")}.md`;
                a.click();
            });

        // ── COPY ──
        document.getElementById("copy-btn")?.addEventListener("click", () => {
            let text = `# ${sessionData.title}\n\n`;
            sessionData.steps.forEach((s, i) => {
                if (s.aiGenerated || s.userInput) {
                    text += `## ${steps[i].title}\n\n${s.aiGenerated || s.userInput}\n\n`;
                }
            });
            navigator.clipboard.writeText(text);
            const btn = document.getElementById("copy-btn");
            btn.textContent = "Copied!";
            setTimeout(() => (btn.textContent = "Copy to clipboard"), 2000);
        });
    </script>
</DashboardLayout>
