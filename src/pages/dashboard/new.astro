---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { connectDB } from "../../lib/db";
import { Framework } from "../../lib/models";

await connectDB();
const frameworks = await Framework.find({}).lean();

const categories = ["all", ...new Set(frameworks.map((fw) => fw.category))];
---

<DashboardLayout title="New Page">
    <div class="p-6">
        <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-800">
                Choose a Framework
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                Pick a storytelling structure to guide your writing.
            </p>
        </div>
        <!-- Controls -->
        <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
            <!-- Category filters -->
            <div class="flex flex-wrap gap-2" id="category-filters">
                {
                    categories.map((cat) => (
                        <button
                            data-category={cat}
                            class={`category-btn text-sm px-3 py-1.5 rounded-full border transition-all ${cat === "all" ? "bg-blue-600 text-white border-blue-600" : "bg-white text-gray-600 border-gray-200 hover:border-blue-400"}`}
                        >
                            {cat === "all"
                                ? "All"
                                : cat.charAt(0).toUpperCase() +
                                  cat.slice(1).replace("-", " ")}
                        </button>
                    ))
                }
            </div>

            <!-- Sort dropdown -->
            <select
                id="sort-select"
                class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 text-gray-600 focus:outline-none focus:border-blue-400"
            >
                <option value="default">Default</option>
                <option value="az">A → Z</option>
                <option value="category">By Category</option>
            </select>
        </div>
        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {
                frameworks.map((fw) => (
                    <a
                        href={`/dashboard/write?framework=${fw.slug}`}
                        data-category={fw.category}
                        data-name={fw.name}
                        class="framework-card block p-5 bg-white border border-gray-200 rounded-xl hover:border-blue-400 hover:shadow-sm transition-all"
                    >
                        <h3 class="font-semibold text-gray-800 mb-1">
                            {fw.name}
                        </h3>
                        <p class="text-sm text-gray-500 mb-3 line-clamp-2">
                            {fw.description}
                        </p>
                        <div class="flex flex-wrap gap-1">
                            {fw.contentTypes?.map((type) => (
                                <span class="text-xs bg-blue-50 text-blue-600 px-2 py-0.5 rounded-full">
                                    {type}
                                </span>
                            ))}
                        </div>
                    </a>
                ))
            }
        </div>
        <!-- Empty state -->
        <p id="empty-state" class="hidden text-center text-gray-400 mt-12">
            No frameworks found.
        </p>
    </div>
</DashboardLayout>
<script>
    const grid = document.getElementById("frameworks-grid");
    const emptyState = document.getElementById("empty-state");
    const sortSelect = document.getElementById(
        "sort-select",
    ) as HTMLSelectElement;
    const categoryBtns = document.querySelectorAll(".category-btn");

    let activeCategory = "all";
    let activeSort = "default";

    function update() {
        const cards = Array.from(
            document.querySelectorAll(".framework-card"),
        ) as HTMLElement[];

        // Sort
        const sorted = [...cards].sort((a, b) => {
            if (activeSort === "az") {
                return (a.dataset.name || "").localeCompare(
                    b.dataset.name || "",
                );
            }
            if (activeSort === "category") {
                return (a.dataset.category || "").localeCompare(
                    b.dataset.category || "",
                );
            }
            return 0;
        });

        // Re-append in sorted order
        sorted.forEach((card) => grid?.appendChild(card));

        // Filter
        let visible = 0;
        sorted.forEach((card) => {
            const match =
                activeCategory === "all" ||
                card.dataset.category === activeCategory;
            card.style.display = match ? "block" : "none";
            if (match) visible++;
        });

        if (emptyState) {
            emptyState.classList.toggle("hidden", visible > 0);
        }
    }

    // Category filter clicks
    categoryBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            activeCategory = (btn as HTMLElement).dataset.category || "all";

            categoryBtns.forEach((b) => {
                b.classList.remove(
                    "bg-blue-600",
                    "text-white",
                    "border-blue-600",
                );
                b.classList.add("bg-white", "text-gray-600", "border-gray-200");
            });
            btn.classList.add("bg-blue-600", "text-white", "border-blue-600");
            btn.classList.remove(
                "bg-white",
                "text-gray-600",
                "border-gray-200",
            );

            update();
        });
    });

    // Sort change
    sortSelect?.addEventListener("change", () => {
        activeSort = sortSelect.value;
        update();
    });
</script>
