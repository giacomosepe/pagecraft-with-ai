---
/**
 * AccountSidebar.astro
 * Usage: import AccountSidebar from "../../components/AccountSidebar.astro";
 * Props:
 *   activeTab: "profile" | "settings" | "billing"
 *   user: Clerk currentUser object
 *   stats: { totalPages: number, completedPages: number, draftPages: number }
 */

interface Props {
    activeTab: string;
    user: {
        firstName?: string | null;
        lastName?: string | null;
        imageUrl?: string | null;
        emailAddresses?: { emailAddress: string }[];
    };
    stats: {
        totalPages: number;
        completedPages: number;
        draftPages: number;
    };
}

const { activeTab, user, stats } = Astro.props;

const initial = (
    user.firstName?.[0] ||
    user.emailAddresses?.[0]?.emailAddress?.[0] ||
    "U"
).toUpperCase();

const fullName = [user.firstName, user.lastName].filter(Boolean).join(" ");
const email = user.emailAddresses?.[0]?.emailAddress ?? "";

const tabs = [
    {
        id: "profile",
        label: "Profile",
        href: "/dashboard/account?tab=profile",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
               </svg>`,
    },
    {
        id: "settings",
        label: "Settings",
        href: "/dashboard/account?tab=settings",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                 <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
               </svg>`,
    },
    {
        id: "billing",
        label: "Billing",
        href: "/dashboard/account?tab=billing",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
               </svg>`,
    },
    {
        id: "prompts",
        label: "Prompts",
        href: "/dashboard/prompts",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
               </svg>`,
    },
];
---

<aside class="w-72 flex-shrink-0 flex flex-col gap-4">

    <!-- ── User card ── -->
    <div class="bg-white border rounded-xl p-5 flex flex-col items-center text-center" style="border-color: var(--color-border)">

        <!-- Avatar -->
        {user.imageUrl ? (
            <img
                src={user.imageUrl}
                alt="Profile photo"
                class="w-20 h-20 rounded-full object-cover ring-4 mb-3"
                style="ring-color: var(--color-accent-light)"
            />
        ) : (
            <div
                class="w-20 h-20 rounded-full flex items-center justify-center text-white text-2xl font-bold mb-3"
                style="background: var(--color-accent)"
            >
                {initial}
            </div>
        )}

        <!-- Name & email -->
        <p class="font-semibold text-base leading-tight" style="color: var(--color-heading)">{fullName}</p>
        <p class="text-sm mt-0.5 truncate max-w-full" style="color: var(--color-muted)">{email}</p>

        <!-- Divider -->
        <div class="w-full my-4" style="border-top: 1px solid var(--color-border)"></div>

        <!-- Stats row -->
        <div class="w-full grid grid-cols-3 gap-2 text-center">
            <div class="flex flex-col">
                <span class="text-xl font-bold" style="color: var(--color-heading)">{stats.totalPages}</span>
                <span class="text-xs mt-0.5" style="color: var(--color-muted)">Pages</span>
            </div>
            <div class="flex flex-col">
                <span class="text-xl font-bold" style="color: var(--color-accent)">{stats.completedPages}</span>
                <span class="text-xs mt-0.5" style="color: var(--color-muted)">Done</span>
            </div>
            <div class="flex flex-col">
                <span class="text-xl font-bold" style="color: var(--color-warning)">{stats.draftPages}</span>
                <span class="text-xs mt-0.5" style="color: var(--color-muted)">Drafts</span>
            </div>
        </div>
    </div>

    <!-- ── Nav tabs ── -->
    <div class="bg-white border rounded-xl overflow-hidden" style="border-color: var(--color-border)">
        <ul class="divide-y" style="border-color: var(--color-border)">
            {tabs.map((tab) => {
                const isActive = activeTab === tab.id;
                return (
                    <li>
                        <a
                            href={tab.href}
                            class="flex items-center gap-3 px-5 py-3.5 text-sm transition-colors"
                            style={isActive
                                ? "background: var(--color-accent-light); color: var(--color-accent-text); font-weight: 600;"
                                : "color: var(--color-body);"}
                        >
                            <!-- Active indicator bar -->
                            <span
                                class="w-1 h-5 rounded-full flex-shrink-0"
                                style={isActive ? "background: var(--color-accent)" : "background: transparent"}
                            ></span>

                            <!-- Icon -->
                            <span class={isActive ? "" : "opacity-50"}>
                                <Fragment set:html={tab.icon} />
                            </span>

                            {tab.label}
                        </a>
                    </li>
                );
            })}
        </ul>
    </div>

    <!-- ── Back link ── -->
    <a
        href="/dashboard"
        class="flex items-center gap-2 text-sm px-1 transition-colors"
        style="color: var(--color-muted)"
    >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Dashboard
    </a>

</aside>
