---
/**
 * GenerateModal.astro
 * -----------------------------------------------------------------
 * Component: Modal that appears when user clicks "Generate with AI"
 * Used in: src/pages/dashboard/write.astro
 * Controlled by: src/scripts/write.ts (generateModal* functions)
 * -----------------------------------------------------------------
 * Shows:
 *   - A read-only preview of the user's input
 *   - The editable Claude prompt (pre-filled from the step default)
 *   - A "Send to Claude" button with loading spinner
 * -----------------------------------------------------------------
 */
---

<div
    id="generate-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center"
    style="background: rgba(0,0,0,0.4)"
>
    <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-lg mx-4">
        <!-- Header -->
        <div class="flex items-center justify-between mb-4">
            <h3
                class="font-semibold text-base"
                style="color: var(--color-heading)"
            >
                Review & Send Prompt
            </h3>
            <button
                id="generate-modal-close"
                style="color: var(--color-muted)"
                aria-label="Close modal"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- User input preview (read-only) -->
        <div class="mb-4">
            <label
                class="block text-sm font-medium mb-1"
                style="color: var(--color-body)"
            >
                Your input
            </label>
            <div
                id="modal-user-input-preview"
                class="text-sm p-3 rounded-md"
                style="background: var(--color-bg); color: var(--color-body); border: 1px solid var(--color-border); min-height: 3rem;"
            >
            </div>
        </div>

        <!-- Editable prompt -->
        <div class="mb-5">
            <label
                class="block text-sm font-medium mb-1"
                style="color: var(--color-body)"
            >
                Prompt sent to Claude
                <span class="font-normal" style="color: var(--color-muted)">
                    (editable)
                </span>
            </label>
            <textarea
                id="modal-prompt-text"
                rows="6"
                class="input resize-none font-mono"
                style="font-size: 0.75rem; color: var(--color-muted)"
            ></textarea>
        </div>

        <!-- Actions -->
        <div class="flex gap-2 justify-end">
            <button id="generate-modal-cancel" class="btn btn-secondary">
                Cancel
            </button>
            <button
                id="generate-modal-send"
                class="btn btn-warning flex items-center gap-2"
            >
                <span id="generate-modal-send-label">✦ Send to Claude</span>
                <svg
                    id="generate-modal-spinner"
                    class="hidden animate-spin w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                >
                    <circle
                        class="opacity-25"
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="4"></circle>
                    <path
                        class="opacity-75"
                        fill="currentColor"
                        d="M4 12a8 8 0 018-8v8H4z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>
